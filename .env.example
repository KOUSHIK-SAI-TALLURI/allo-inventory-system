# Database (Supabase / Neon / Railway — hosted Postgres required)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Redis (Upstash recommended — free tier works)
REDIS_URL="redis://default:password@host:6379"

# Cron job protection secret (generate with: openssl rand -hex 32)
CRON_SECRET="your-secret-here"
